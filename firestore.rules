rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Admins helper
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "admin1@sdstudios.com" ||
        request.auth.token.email == "admin2@sdstudios.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Products
    match /products/{productId} {
      allow read, list: if true;
      
      function isValidProduct(data) {
        return data.title is string && data.title.size() <= 100 &&
               data.price is string && data.price.size() <= 20 &&
               data.tag is string && data.tag.size() <= 50 &&
               data.color is string && data.color.size() <= 200;
      }

      // Anyone can create if shape is valid (shop catalog seed / first-time stock).
      // Updates and deletes remain admin-only so the storefront cannot be vandalised.
      allow create: if isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    // Admins
    match /admins/{adminId} {
      allow read: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      // Special rule: Allow first user to register if collection is empty
      // WARNING: In production, you'd seed this via Cloud Functions or CLI
      allow create: if isSignedIn() && (
        request.auth.token.email == "66shashwatkumar66@gmail.com" || 
        isAdmin()
      );
    }
    
    // Orders
    match /orders/{orderId} {
      allow create: if true;
      allow get: if true; // Allow anyone with an ID to track their order
      allow list: if isAdmin();
    }

    // Contact form (website → admin inbox)
    match /contactMessages/{messageId} {
      allow create: if request.resource.data.keys().hasOnly(['name', 'email', 'message', 'createdAt']) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() >= 2 &&
        request.resource.data.name.size() <= 120 &&
        request.resource.data.email is string &&
        request.resource.data.email.size() <= 200 &&
        request.resource.data.message is string &&
        request.resource.data.message.size() >= 10 &&
        request.resource.data.message.size() <= 8000 &&
        request.resource.data.createdAt == request.time;
      allow read, list: if isAdmin();
    }

    // Settings
    match /settings/global {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Testing connection
    match /test/connection {
      allow read: if true;
    }
  }
}
